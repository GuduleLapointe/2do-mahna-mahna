{
	"name": "magicoli/2do-aggregator",
	"version": "3.0.0-dev",
	"description": "PHP port of 2do-server, collects calendars from several sources and make them available under different formats ffor 2do-events, ics, json...",
	"type": "project",
	"license": "AGPL-3.0-or-later",
	"authors": [
		{
			"name": "Gudule Lapointe",
			"email": "gudule@speculoos.world"
		}
	],
	"require": {
		"kigkonsult/icalcreator": "^2.41",
		"matthiasmullie/minify": "^1.3",
		"erusev/parsedown": "^1.7",
		"symfony/browser-kit": "^7.0",
		"symfony/http-client": "^7.0",
		"symfony/css-selector": "^7.0",
		"phpxmlrpc/phpxmlrpc": "^4.11",
		"filament/filament": "^3.3"
	},
	"autoload": {
		"classmap": [
			"app/",
			"lib/"
		]
	},
	"require-dev": {
		"magicoli/php-bump-library": "^1.0",
		"phpunit/phpunit": "^10.1",
		"pestphp/pest": "^2.0",
		"squizlabs/php_codesniffer": "^3.13",
		"phpcompatibility/php-compatibility": "^9.3"
	},
	"scripts": {
		"bump-version": "vendor/magicoli/php-bump-library/vendor/bin/robo --load-from=vendor/magicoli/php-bump-library/RoboFile.php bump:version"
	},
	"config": {
		"allow-plugins": {
			"pestphp/pest-plugin": true
		},
		"platform": {
			"php": "8.2"
		}
	}
}
