# Route legacy LSL endpoints and /api/ tree through the front controller,
# even when static files exist (e.g. events.lsl2 generated by the aggregator).
RewriteEngine On
RewriteRule ^(events\.lsl[23]?|api/.*)$ index.php [QSA,L]

# Route any other path that doesn't map to an existing file or directory.
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
